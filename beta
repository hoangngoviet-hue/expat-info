<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ExpaTrak — Gradion Internal Tool</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Firebase v10 compat (no bundler required) -->
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Gradion brand ── */
      --brand:       #ff6b00;
      --brand-dark:  #e05e00;
      --brand-deeper:#c25200;

      /* ── Layout ── */
      --bg:     #f0f2f5;
      --card:   #ffffff;
      --border: #e2e8f0;
      --txt:    #0f172a;
      --txt2:   #64748b;
      --txt3:   #94a3b8;

      /* ── Status colours (unchanged — functional, not brand) ── */
      --green:  #10b981; --green-l:  #d1fae5; --green-d:  #065f46;
      --blue:   #3b82f6; --blue-l:   #dbeafe; --blue-d:   #1d4ed8;
      --yellow: #f59e0b; --yellow-l: #fef3c7; --yellow-d: #92400e;
      --warn:   #f97316; --warn-l:   #fed7aa; --warn-d:   #9a3412;
      --red:    #ef4444; --red-l:    #fee2e2; --red-d:    #991b1b;
      --gray:   #94a3b8; --gray-l:   #f1f5f9;

      --font: 'Inter', system-ui, sans-serif;
      --r: 12px; --r2: 8px;
      --sh:  0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
      --shm: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -1px rgba(0,0,0,.06);
    }

    body { font-family: var(--font); background: var(--bg); color: var(--txt); min-height: 100vh; display: flex; }

    /* ══════════════════════════════════
       LOGIN SCREEN
    ══════════════════════════════════ */
    #loginScreen {
      position: fixed; inset: 0; z-index: 200;
      background: var(--brand);
      display: flex; align-items: center; justify-content: center;
      /* subtle noise texture */
      background-image: radial-gradient(circle at 20% 80%, rgba(255,255,255,.07) 0%, transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(0,0,0,.1) 0%, transparent 50%);
    }
    #loginScreen.hidden { display: none; }

    .login-card {
      background: #fff;
      border-radius: 20px;
      width: 420px;
      max-width: 95vw;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(0,0,0,.25);
    }
    .login-header {
      background: var(--brand);
      padding: 28px 32px 24px;
      color: white;
    }
    .login-logo {
      display: flex; align-items: center; gap: 10px; margin-bottom: 20px;
    }
    .login-logo-mark {
      width: 40px; height: 40px; border-radius: 8px;
      background: rgba(255,255,255,.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; font-weight: 900; color: #fff; letter-spacing: -1px;
    }
    .login-logo-text { line-height: 1; }
    .login-logo-text .brand-name { font-size: 17px; font-weight: 800; letter-spacing: 1.5px; color: #fff; }
    .login-logo-text .brand-sub  { font-size: 9px; font-weight: 400; color: rgba(255,255,255,.7); letter-spacing: .5px; margin-top: 2px; }
    .login-product-name { font-size: 26px; font-weight: 700; color: #fff; letter-spacing: -.5px; }
    .login-product-sub  { font-size: 13px; color: rgba(255,255,255,.75); margin-top: 4px; }

    .login-body { padding: 28px 32px 32px; }
    .login-body h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .login-body p  { font-size: 12px; color: var(--txt2); margin-bottom: 22px; line-height: 1.5; }

    .btn-google {
      width: 100%;
      display: flex; align-items: center; justify-content: center; gap: 10px;
      padding: 12px 20px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      background: #fff;
      font-size: 14px; font-weight: 600; color: var(--txt);
      cursor: pointer; font-family: var(--font);
      transition: all .18s;
    }
    .btn-google:hover { border-color: var(--brand); background: #fff5ee; box-shadow: 0 0 0 3px rgba(255,107,0,.12); }
    .btn-google svg { flex-shrink: 0; }

    .login-divider { height: 1px; background: var(--border); margin: 20px 0; }

    .login-notice {
      display: flex; align-items: flex-start; gap: 8px;
      padding: 12px 14px; background: #fff5ee;
      border: 1px solid rgba(255,107,0,.25);
      border-radius: 8px; font-size: 11px; color: var(--warn-d); line-height: 1.5;
    }
    .login-notice .icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }

    #loginError {
      margin-top: 14px; padding: 10px 13px;
      background: var(--red-l); border-radius: 8px;
      font-size: 12px; color: var(--red-d); font-weight: 500;
      display: none;
    }

    /* ══════════════════════════════════
       MAIN APP
    ══════════════════════════════════ */
    #app { display: flex; width: 100%; }
    #app.hidden { display: none; }

    /* ── Sidebar (Gradion orange) ── */
    .sidebar {
      width: 270px; min-height: 100vh; background: var(--brand);
      display: flex; flex-direction: column; flex-shrink: 0;
      position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }

    .sb-logo {
      padding: 20px 18px 18px;
      border-bottom: 1px solid rgba(255,255,255,.18);
    }
    .sb-logo-row {
      display: flex; align-items: center; gap: 9px; margin-bottom: 14px;
    }
    .sb-logo-mark {
      width: 36px; height: 36px; border-radius: 7px;
      background: rgba(255,255,255,.22);
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; font-weight: 900; color: #fff;
      flex-shrink: 0;
    }
    .sb-brand-name { font-size: 15px; font-weight: 800; letter-spacing: 1.2px; color: #fff; }
    .sb-brand-sub  { font-size: 9px; color: rgba(255,255,255,.65); letter-spacing: .4px; margin-top: 1px; }
    .sb-product    { font-size: 12px; font-weight: 600; color: rgba(255,255,255,.9); letter-spacing: .2px; }
    .sb-product-sub{ font-size: 10px; color: rgba(255,255,255,.6); margin-top: 2px; }

    .sb-search { padding: 12px 16px; }
    .sb-search input {
      width: 100%; background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.2);
      border-radius: 7px; padding: 7px 11px;
      color: #fff; font-size: 12px; font-family: var(--font); outline: none;
    }
    .sb-search input::placeholder { color: rgba(255,255,255,.55); }
    .sb-search input:focus { border-color: rgba(255,255,255,.5); background: rgba(255,255,255,.2); }

    .sb-section {
      padding: 5px 18px 3px;
      font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 1px;
      color: rgba(255,255,255,.45);
    }

    .expat-item {
      margin: 3px 8px; padding: 9px 11px; border-radius: 7px;
      cursor: pointer; transition: background .15s;
      display: flex; align-items: center; gap: 9px;
    }
    .expat-item:hover  { background: rgba(0,0,0,.12); }
    .expat-item.active { background: rgba(0,0,0,.22); }
    .e-avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
    .e-info { flex: 1; min-width: 0; }
    .e-name { font-size: 12px; font-weight: 500; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .e-role { font-size: 10px; color: rgba(255,255,255,.55); }
    .e-dot  { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

    .sb-footer {
      margin-top: auto; padding: 14px 16px;
      border-top: 1px solid rgba(255,255,255,.18);
    }
    .sb-user {
      display: flex; align-items: center; gap: 9px; margin-bottom: 10px;
    }
    .sb-user-av {
      width: 32px; height: 32px; border-radius: 50%;
      background: rgba(255,255,255,.25); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: #fff;
      overflow: hidden;
    }
    .sb-user-av img { width: 100%; height: 100%; object-fit: cover; }
    .sb-user-name  { font-size: 11px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-user-email { font-size: 10px; color: rgba(255,255,255,.55); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .btn-signout {
      width: 100%; padding: 7px; border-radius: 6px;
      background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
      color: rgba(255,255,255,.85); font-size: 11px; font-weight: 500;
      cursor: pointer; font-family: var(--font); transition: background .15s;
    }
    .btn-signout:hover { background: rgba(255,255,255,.22); }

    /* ── Main content area ── */
    .main { flex: 1; min-width: 0; overflow-y: auto; }
    .topbar {
      background: #fff; border-bottom: 1px solid var(--border); padding: 13px 26px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 20;
    }
    .tb-title { font-size: 14px; font-weight: 600; }
    .tb-sub   { font-size: 11px; color: var(--txt2); margin-top: 1px; }

    .btn {
      display: inline-flex; align-items: center; gap: 5px; padding: 7px 14px;
      border-radius: 7px; font-size: 12px; font-weight: 600; cursor: pointer;
      border: none; font-family: var(--font); transition: all .15s;
    }
    .btn-primary { background: var(--brand); color: #fff; }
    .btn-primary:hover { background: var(--brand-dark); }
    .btn-ghost { background: transparent; color: var(--txt2); border: 1.5px solid var(--border); }
    .btn-ghost:hover { background: var(--gray-l); }

    .content { padding: 22px 26px; }

    /* ── Badges ── */
    .badge {
      display: inline-flex; align-items: center; gap: 3px; padding: 3px 9px;
      border-radius: 100px; font-size: 10px; font-weight: 600;
    }
    .badge-brand  { background: #fff3eb; color: var(--brand); }
    .badge-blue   { background: var(--blue-l);   color: var(--blue-d); }
    .badge-green  { background: var(--green-l);  color: var(--green-d); }
    .badge-yellow { background: var(--yellow-l); color: var(--yellow-d); }
    .badge-orange { background: var(--warn-l);   color: var(--warn-d); }
    .badge-red    { background: var(--red-l);     color: var(--red-d); }
    .badge-gray   { background: var(--gray-l);    color: var(--txt2); }

    /* ── Hero card ── */
    .hero-card {
      background: #fff; border-radius: var(--r); padding: 22px;
      display: flex; align-items: center; gap: 18px;
      box-shadow: var(--sh); margin-bottom: 20px;
    }
    .hero-av { width: 60px; height: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; flex-shrink: 0; }
    .hero-info { flex: 1; }
    .hero-name   { font-size: 18px; font-weight: 700; letter-spacing: -.4px; }
    .hero-meta   { font-size: 12px; color: var(--txt2); margin-top: 3px; }
    .hero-badges { display: flex; gap: 6px; margin-top: 9px; flex-wrap: wrap; }
    .hero-stats  { display: flex; gap: 22px; }
    .stat   { text-align: center; }
    .stat-v { font-size: 20px; font-weight: 700; }
    .stat-l { font-size: 10px; color: var(--txt2); margin-top: 1px; }

    /* ── Section header ── */
    .sec-hdr   { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .sec-title { font-size: 13px; font-weight: 600; }
    .sec-sub   { font-size: 11px; color: var(--txt2); }

    /* ── Stepper ── */
    .stepper-card { background: #fff; border-radius: var(--r); padding: 22px; box-shadow: var(--sh); margin-bottom: 20px; overflow-x: auto; }
    .phase-row  { display: flex; gap: 6px; margin-bottom: 10px; min-width: 680px; }
    .phase-lbl  { padding: 4px 12px; border-radius: 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
    .phase-pre  { background: #fff3eb; color: var(--brand); flex: 4; }
    .phase-post { background: var(--green-l); color: var(--green-d); flex: 3; }
    .stepper    { display: flex; align-items: flex-start; min-width: 680px; position: relative; padding-top: 6px; }
    .step-line  { position: absolute; top: 18px; left: 22px; right: 22px; height: 2px; background: var(--border); z-index: 0; }
    .step-fill  { height: 100%; background: var(--green); transition: width .5s ease; }
    .step-item  { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1; cursor: pointer; }
    .step-circle {
      width: 36px; height: 36px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700;
      border: 2px solid var(--border); background: #fff; transition: all .2s;
    }
    .step-item.completed       .step-circle { background: var(--green);  border-color: var(--green); color: #fff; }
    .step-item.in_progress     .step-circle { background: var(--brand);  border-color: var(--brand); color: #fff; box-shadow: 0 0 0 4px rgba(255,107,0,.2); }
    .step-item.action_required .step-circle { background: var(--warn);   border-color: var(--warn);  color: #fff; }
    .step-item.overdue         .step-circle { background: var(--red);    border-color: var(--red);   color: #fff; }
    .step-item.pending         .step-circle { color: var(--txt3); }
    .step-label { text-align: center; margin-top: 8px; max-width: 86px; }
    .sl-name { font-size: 10px; font-weight: 600; line-height: 1.3; }
    .sl-date { font-size: 9px; color: var(--txt3); margin-top: 1px; }
    .sl-resp { font-size: 9px; color: var(--txt2); margin-top: 1px; font-style: italic; }

    /* ── Legend ── */
    .legend { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 14px; }
    .lg-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--txt2); }
    .lg-dot  { width: 10px; height: 10px; border-radius: 2px; }

    /* ── Gantt ── */
    .gantt-card  { background: #fff; border-radius: var(--r); padding: 22px; box-shadow: var(--sh); margin-bottom: 20px; overflow-x: auto; }
    .gantt-wrap  { min-width: 760px; }
    .gantt-row   { display: flex; align-items: center; margin-bottom: 7px; min-height: 38px; }
    .gantt-lbl   { width: 190px; flex-shrink: 0; padding-right: 14px; }
    .gl-name     { font-size: 11px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .gl-resp     { font-size: 10px; color: var(--txt3); margin-top: 1px; }
    .gantt-track { flex: 1; height: 34px; background: var(--gray-l); border-radius: 4px; position: relative; overflow: visible; }
    .gantt-bar {
      position: absolute; height: 100%; border-radius: 4px;
      display: flex; align-items: center; padding: 0 7px;
      font-size: 10px; font-weight: 600; color: #fff;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      cursor: pointer; transition: filter .15s;
    }
    .gantt-bar:hover { filter: brightness(.88); }
    .gantt-bar.completed       { background: var(--green); }
    .gantt-bar.in_progress     { background: var(--brand); }
    .gantt-bar.action_required { background: var(--warn); }
    .gantt-bar.overdue         { background: var(--red); }
    .gantt-bar.pending         { background: var(--gray); }
    .today-line { position: absolute; top: 0; bottom: 0; width: 2px; background: rgba(239,68,68,.85); z-index: 8; pointer-events: none; }

    /* ── Doc cards ── */
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-bottom: 20px; }
    .doc-card { background: #fff; border-radius: var(--r); padding: 18px; box-shadow: var(--sh); border-left: 4px solid var(--border); }
    .doc-card.c-green  { border-left-color: var(--green); }
    .doc-card.c-blue   { border-left-color: var(--blue); }
    .doc-card.c-brand  { border-left-color: var(--brand); }
    .doc-card.c-yellow { border-left-color: var(--yellow); }
    .doc-card.c-orange { border-left-color: var(--warn); }
    .doc-card.c-red    { border-left-color: var(--red); }
    .doc-card.c-gray   { border-left-color: var(--gray); }
    .dc-hdr  { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .dc-title{ font-size: 13px; font-weight: 600; }
    .dc-sub  { margin-top: 3px; }
    .dc-rows { display: flex; flex-direction: column; gap: 7px; }
    .dc-row  { display: flex; justify-content: space-between; align-items: center; padding: 7px 9px; background: var(--gray-l); border-radius: 5px; font-size: 11px; }
    .dc-row-lbl { color: var(--txt2); }
    .dc-row-val { font-weight: 600; }
    .dc-action { margin-top: 12px; padding: 9px 11px; border-radius: 7px; font-size: 11px; font-weight: 500; }
    .a-warn  { background: var(--yellow-l); color: var(--yellow-d); }
    .a-ok    { background: var(--green-l);  color: var(--green-d); }
    .a-urgent{ background: var(--red-l);    color: var(--red-d); }
    .a-proc  { background: #fff3eb;         color: var(--brand); }
    .a-idle  { background: var(--gray-l);   color: var(--txt2); }

    /* ── Renewal ── */
    .renewal-card { background: #fff; border-radius: var(--r); padding: 22px; box-shadow: var(--sh); margin-bottom: 20px; }
    .rn-info-row  { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 18px; }
    .rn-box       { padding: 10px 13px; border-radius: 7px; font-size: 11px; }

    /* ── Biz trips ── */
    .biz-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
    .biz-card { background: #fff; border-radius: var(--r); padding: 18px; box-shadow: var(--sh); }
    .biz-prog { margin-top: 14px; height: 6px; background: var(--gray-l); border-radius: 3px; overflow: hidden; }
    .biz-fill { height: 100%; border-radius: 3px; transition: width .5s; }

    /* ── Tooltip ── */
    .tooltip {
      position: fixed; background: #1e293b; color: #fff; padding: 10px 13px;
      border-radius: 8px; font-size: 11px; pointer-events: none; z-index: 9999;
      max-width: 230px; box-shadow: var(--shm); display: none;
    }
    .tt-title { font-weight: 600; margin-bottom: 4px; font-size: 12px; }
    .tt-row   { color: #94a3b8; margin-top: 2px; }
    .tt-row span { color: #fff; font-weight: 500; }

    /* ── Add Expat Modal ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: none; align-items: center; justify-content: center; z-index: 100; }
    .modal { background: #fff; border-radius: 14px; padding: 26px; width: 460px; max-width: 95vw; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.2); }
    .modal-title    { font-size: 16px; font-weight: 700; margin-bottom: 18px; }
    .form-group     { margin-bottom: 14px; }
    .form-label     { font-size: 12px; font-weight: 500; margin-bottom: 5px; display: block; }
    .form-input     { width: 100%; padding: 9px 11px; border: 1.5px solid var(--border); border-radius: 7px; font-size: 12px; font-family: var(--font); outline: none; transition: border-color .15s; }
    .form-input:focus { border-color: var(--brand); }
    .form-row       { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .modal-actions  { display: flex; gap: 9px; justify-content: flex-end; margin-top: 18px; }

    /* ── Empty state ── */
    .empty { text-align: center; padding: 70px 20px; color: var(--txt2); }
    .empty h3 { font-size: 15px; font-weight: 600; margin-bottom: 7px; }
    .empty p  { font-size: 12px; }

    /* ── Loading spinner ── */
    .spinner-overlay {
      position: fixed; inset: 0; background: var(--brand);
      display: flex; align-items: center; justify-content: center;
      z-index: 300;
    }
    .spinner-overlay.hidden { display: none; }
    .spinner {
      width: 40px; height: 40px; border: 3px solid rgba(255,255,255,.3);
      border-top-color: #fff; border-radius: 50%;
      animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }

    @media (max-width: 860px) { .sidebar { display: none; } .hero-stats { display: none; } }
  </style>
</head>
<body>

<!-- Loading state -->
<div id="spinnerOverlay" class="spinner-overlay">
  <div class="spinner"></div>
</div>

<!-- Tooltip -->
<div id="tooltip" class="tooltip"></div>

<!-- ══════════════════════════════════════
     LOGIN SCREEN
══════════════════════════════════════ -->
<div id="loginScreen" class="hidden">
  <div class="login-card">
    <div class="login-header">
      <div class="login-logo">
        <div class="login-logo-mark">G</div>
        <div class="login-logo-text">
          <div class="brand-name">GRADION</div>
          <div class="brand-sub">scaling business</div>
        </div>
      </div>
      <div class="login-product-name">ExpaTrak</div>
      <div class="login-product-sub">Document Timeline Manager — Internal Tool</div>
    </div>
    <div class="login-body">
      <h3>Welcome back</h3>
      <p>Sign in with your Gradion Google Workspace account to access the expat document timeline system.</p>

      <button class="btn-google" onclick="signInWithGoogle()">
        <!-- Google "G" SVG -->
