      </div>
      <div class="e-dot" style="background:${DOT_COL[e.overallStatus]||'rgba(255,255,255,.4)'}"></div>
    </div>`).join('');
}

function filterExpats(q) {
  q = q.toLowerCase();
  document.querySelectorAll('.expat-item').forEach(el => {
    el.style.display = el.querySelector('.e-name').textContent.toLowerCase().includes(q) ? '' : 'none';
  });
