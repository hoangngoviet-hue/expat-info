let selectedId = null;

function renderSidebar() {
  document.getElementById('expatList').innerHTML = EXPATS.map(e => `
    <div class="expat-item${selectedId===e.id?' active':''}" onclick="selectExpat(${e.id})">
      <div class="e-avatar" style="background:rgba(255,255,255,.2);color:#fff;font-size:12px">${e.initials}</div>
      <div class="e-info">
