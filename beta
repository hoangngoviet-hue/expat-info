  document.getElementById('tbSub').textContent = `${e.position} · ${e.dept} · ${e.company}`;
  document.getElementById('mainContent').innerHTML =
    heroCard(e) + stepperSection(e) + ganttSection(e) + docSection(e) +
    renewalSection(e) + tripsSection(e);
}

// ── Hero ──────────────────────────────────────────────
function heroCard(e) {
  const done = e.steps.filter(s => s.status==='completed').length;
  const pct  = Math.round(done/7*100);
  const dts  = D.diff(TODAY, e.targetStart);
  const overall = {
    in_progress:     `<span class="badge badge-brand">🟠 In Progress</span>`,
    action_required: `<span class="badge badge-orange">⚠ Action Required</span>`,
    renewal_due:     `<span class="badge badge-yellow">⏰ Renewal Due</span>`,
    on_track:        `<span class="badge badge-blue">📅 On Track</span>`,
    completed:       `<span class="badge badge-green">✓ Completed</span>`
  }[e.overallStatus]||'';
  const arrBadge = e.arrived
    ? `<span class="badge badge-green">✅ In Vietnam</span>`
    : dts>0
      ? `<span class="badge badge-gray">${dts}d to start</span>`
      : `<span class="badge badge-red">Started ${Math.abs(dts)}d ago</span>`;
  return `
  <div class="hero-card">
    <div class="hero-av" style="background:${e.color}18;color:${e.color}">${e.initials}</div>
    <div class="hero-info">
      <div class="hero-name">${e.name}</div>
      <div class="hero-meta">${e.nat} · ${e.position} · ${e.dept}</div>
      <div class="hero-badges">
        ${overall} ${arrBadge}
        <span class="badge badge-gray">Step ${e.currentStep}/7</span>
        <span class="badge badge-gray">Passport exp. ${D.fmt(e.passportExpiry)}</span>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><div class="stat-v" style="color:var(--brand)">${pct}%</div><div class="stat-l">Complete</div></div>
      <div class="stat"><div class="stat-v">${done}/7</div><div class="stat-l">Steps Done</div></div>
      <div class="stat">
        <div class="stat-v" style="color:${dts<0?'#10b981':'var(--brand)'}">${Math.abs(dts)}</div>
        <div class="stat-l">${dts<0?'Days Since Start':'Days to Start'}</div>
      </div>
    </div>
  </div>`;
}

// ── Stepper ───────────────────────────────────────────
function stepperSection(e) {
  const done = e.steps.filter(s => s.status==='completed').length;
  const fillPct = (done/(e.steps.length-1))*100;
  return `
  <div class="sec-hdr"><div><div class="sec-title">Onboarding Progress</div><div class="sec-sub">Phase 1: Pre-Arrival &amp; WP → Phase 2: Post-Arrival &amp; TRC</div></div></div>
  <div class="stepper-card">
    <div class="phase-row">
      <div class="phase-lbl phase-pre">📋 Phase 1 — Pre-Arrival &amp; Work Permit (Steps 1–4)</div>
      <div class="phase-lbl phase-post">🇻🇳 Phase 2 — Post-Arrival &amp; TRC (Steps 5–7)</div>
    </div>
    <div class="stepper">
      <div class="step-line"><div class="step-fill" style="width:${fillPct}%"></div></div>
      ${e.steps.map(s=>`
      <div class="step-item ${s.status}" title="${s.notes||s.name}">
        <div class="step-circle">${STEP_ICONS[s.status]||s.id}</div>
        <div class="step-label">
          <div class="sl-name">${s.name}</div>
          <div class="sl-date">${s.start?D.fmtShort(s.start):'—'}</div>
          <div class="sl-resp">${s.resp}</div>
        </div>
      </div>`).join('')}
    </div>
  </div>`;
}

// ── Gantt ─────────────────────────────────────────────
function ganttSection(e) {
  const dated = e.steps.filter(s=>s.start&&s.end);
  if (!dated.length) return '';
  const allMs  = dated.flatMap(s=>[+new Date(s.start),+new Date(s.end)]);
  let rMin = new Date(Math.min(...allMs)); rMin.setDate(rMin.getDate()-5);
  let rMax = new Date(Math.max(...allMs)); rMax.setDate(rMax.getDate()+10);
  const total  = D.diff(rMin,rMax);
  const tPct   = clamp((D.diff(rMin,TODAY)/total)*100,0,100);

  const months = [];
  const cur = new Date(rMin); cur.setDate(1);
  while (cur<=rMax) {
    const p=(D.diff(rMin,cur)/total)*100;
    if (p>=0&&p<=100) months.push({lbl:cur.toLocaleDateString('en-GB',{month:'short',year:'2-digit'}),p});
    cur.setMonth(cur.getMonth()+1);
  }

  const rows = e.steps.map(s=>{
    if (!s.start||!s.end) return `
      <div class="gantt-row">
        <div class="gantt-lbl"><div class="gl-name">${s.id}. ${s.name}</div><div class="gl-resp">${s.resp}</div></div>
        <div class="gantt-track" style="position:relative">
          <span style="position:absolute;inset:0;display:flex;align-items:center;padding:0 10px;font-size:10px;color:var(--txt3)">Date TBD</span>
          ${tPct>0&&tPct<100?`<div class="today-line" style="left:${tPct}%"></div>`:''}
        </div>
      </div>`;
    const sp=clamp((D.diff(rMin,s.start)/total)*100,0,100);
    const ep=clamp((D.diff(rMin,s.end)/total)*100,0,100);
    const w=Math.max(.8,ep-sp);
    const dur=D.diff(s.start,s.end);
    const note=(s.notes||'').replace(/'/g,"&apos;");
    return `
      <div class="gantt-row">
        <div class="gantt-lbl"><div class="gl-name">${s.id}. ${s.name}</div><div class="gl-resp">${s.resp}</div></div>
        <div class="gantt-track" style="position:relative">
          <div class="gantt-bar ${s.status}" style="left:${sp}%;width:${w}%"
            onmouseenter="showTT(event,'${s.name}','${D.fmt(s.start)}','${D.fmt(s.end)}','${dur} days','${s.resp}','${note}')"
            onmouseleave="hideTT()">${w>7?dur+'d':''}</div>
          ${tPct>0&&tPct<100?`<div class="today-line" style="left:${tPct}%"></div>`:''}
        </div>
      </div>`;
  }).join('');

  return `
  <div class="sec-hdr" style="margin-top:22px"><div>
    <div class="sec-title">Timeline Gantt Chart</div>
    <div class="sec-sub">Hover bars for details · <span style="color:#ef4444;font-weight:600">Red line = Today</span></div>
  </div></div>
  <div class="legend">
    <div class="lg-item"><div class="lg-dot" style="background:var(--green)"></div>Completed</div>
    <div class="lg-item"><div class="lg-dot" style="background:var(--brand)"></div>In Progress</div>
    <div class="lg-item"><div class="lg-dot" style="background:var(--warn)"></div>Action Required</div>
    <div class="lg-item"><div class="lg-dot" style="background:var(--red)"></div>Overdue / Strict Deadline</div>
    <div class="lg-item"><div class="lg-dot" style="background:var(--gray)"></div>Pending</div>
  </div>
  <div class="gantt-card">
    <div class="gantt-wrap">
      <div style="margin-left:190px;margin-bottom:6px;position:relative;height:20px">
        ${months.map(m=>`<span style="position:absolute;left:${m.p}%;transform:translateX(-50%);font-size:10px;color:var(--txt3);font-weight:500">${m.lbl}</span>`).join('')}
      </div>
      ${rows}
      <div style="margin-left:190px;margin-top:6px;display:flex;justify-content:space-between;font-size:10px;color:var(--txt3)">
        <span>${D.fmt(rMin)}</span>
        <span style="color:#ef4444;font-weight:600">▲ Today: ${D.fmt(TODAY)}</span>
        <span>${D.fmt(rMax)}</span>
      </div>
    </div>
  </div>`;
}

// ── Doc cards ─────────────────────────────────────────
function docSection(e) {
  return `
  <div class="sec-hdr" style="margin-top:22px">
    <div><div class="sec-title">Document Status</div><div class="sec-sub">Processing time · Key dates · Responsible party</div></div>
  </div>
  <div class="cards-grid">
    ${docCard('🛂',e.docs.entryVisa)}
    ${docCard('📄',e.docs.wp)}
    ${docCard('🪪',e.docs.trc)}
  </div>`;
}

function docCard(icon, doc) {
  const c   = S_COLOR[doc.status]||'gray';
  const lbl = S_LABEL[doc.status]||doc.status;
  const dte = doc.expiry ? D.diff(TODAY,doc.expiry) : null;
  const exC = dte!==null&&dte<45 ? 'var(--red)' : 'inherit';
  let action='';
  if      (doc.status==='renewal_due')                         action=`<div class="dc-action a-warn">⚠ Start renewal now — ${dte} days remaining</div>`;
  else if (doc.status==='action_required')                     action=`<div class="dc-action a-warn">⚠ Submit documents immediately</div>`;
  else if (doc.status==='expiring_soon')                       action=`<div class="dc-action a-warn">⏰ Expires in ${dte} days — act now</div>`;
  else if (doc.status==='processing'||doc.status==='in_progress') action=`<div class="dc-action a-proc">⏳ Processing: ${doc.proc}</div>`;
  else if (['active','completed','approved'].includes(doc.status)) action=`<div class="dc-action a-ok">✓ No action required${dte!==null?` · ${dte}d remaining`:''}</div>`;
  else if (['pending','not_started'].includes(doc.status))     action=`<div class="dc-action a-idle">⏸ Waiting for prior steps</div>`;
  return `
  <div class="doc-card c-${c}">
    <div class="dc-hdr">
      <div><div class="dc-title">${icon} ${doc.lbl}</div><div class="dc-sub"><span class="badge badge-${c}">${lbl}</span></div></div>
      <span style="font-size:24px">${icon}</span>
    </div>
    <div class="dc-rows">
      <div class="dc-row"><span class="dc-row-lbl">Processing Time</span><span class="dc-row-val">${doc.proc||'—'}</span></div>
      <div class="dc-row"><span class="dc-row-lbl">Issued Date</span><span class="dc-row-val">${D.fmt(doc.issued)}</span></div>
      <div class="dc-row"><span class="dc-row-lbl">Expiry Date</span><span class="dc-row-val" style="color:${exC}">${D.fmt(doc.expiry)}</span></div>
      <div class="dc-row"><span class="dc-row-lbl">Responsible</span><span class="dc-row-val">Admin</span></div>
    </div>
    ${action}
  </div>`;
}

// ── Renewal Timeline ──────────────────────────────────
function renewalSection(e) {
  if (!e.docs.wp.expiry) return '';
  const exp  = new Date(e.docs.wp.expiry);
  const rS   = D.add(exp,-45);
  const rD   = D.add(exp,-5);
  const rMin = D.add(rS,-10);
  const rMax = D.add(exp,20);
  const tot  = D.diff(rMin,rMax);
  const pct  = d => clamp((D.diff(rMin,d)/tot)*100,0,100);
  const tP=pct(TODAY), rsP=pct(rS), rdP=pct(rD), eP=pct(exp);
  const dtsE=D.diff(TODAY,exp), dtsRs=D.diff(TODAY,rS), dtsRd=D.diff(TODAY,rD);
  return `
  <div class="sec-hdr" style="margin-top:22px">
    <div><div class="sec-title">WP / TRC Renewal Timeline</div><div class="sec-sub">Based on WP expiry: ${D.fmt(exp)}</div></div>
  </div>
  <div class="renewal-card">
    <div class="rn-info-row">
      <div class="rn-box" style="background:var(--warn-l)">
        <div style="font-weight:600;color:var(--warn-d)">Renewal Window Opens</div>
        <div style="color:var(--warn-d);font-size:12px;margin-top:2px">${D.fmt(rS)}</div>
        <div style="font-size:10px;color:var(--warn-d);margin-top:2px">${dtsRs>0?`In ${dtsRs} days`:`${Math.abs(dtsRs)} days ago`}</div>
      </div>
      <div class="rn-box" style="background:var(--red-l)">
        <div style="font-weight:600;color:var(--red-d)">🚨 Absolute Deadline</div>
        <div style="color:var(--red-d);font-size:12px;margin-top:2px">${D.fmt(rD)}</div>
        <div style="font-size:10px;color:var(--red-d);margin-top:2px">${dtsRd>0?`In ${dtsRd} days`:`${Math.abs(dtsRd)} days ago · OVERDUE`}</div>
      </div>
      <div class="rn-box" style="background:var(--gray-l)">
        <div style="font-weight:600">WP Expiry Date</div>
        <div style="font-size:12px;margin-top:2px">${D.fmt(exp)}</div>
        <div style="font-size:10px;color:var(--txt2);margin-top:2px">${dtsE>0?`In ${dtsE} days`:`Expired ${Math.abs(dtsE)} days ago`}</div>
      </div>
    </div>
    <div style="position:relative;padding-top:28px;padding-bottom:8px">
      <div style="height:30px;border-radius:7px;position:relative;overflow:hidden;
        background:linear-gradient(to right,
          var(--green-l) 0%,       var(--green-l) ${rsP}%,
          var(--yellow-l)${rsP}%,  var(--yellow-l)${rdP}%,
          var(--red-l)   ${rdP}%,  var(--red-l)   ${eP}%,
          var(--gray-l)  ${eP}%)">
        <div style="position:absolute;top:0;bottom:0;left:${tP}%;width:2px;background:#ef4444;z-index:5"></div>
        <div style="position:absolute;top:0;bottom:0;left:${rsP}%;width:2px;background:var(--warn)"></div>
        <div style="position:absolute;top:0;bottom:0;left:${rdP}%;width:2px;background:var(--red)"></div>
      </div>
      <div style="position:absolute;top:4px;left:${tP}%;transform:translateX(-50%);font-size:10px;font-weight:700;color:#ef4444;white-space:nowrap">Today ▼</div>
      <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:10px;color:var(--txt3)">
        <span>${D.fmt(rMin)}</span>
        <span style="color:var(--warn);font-weight:600">▲ Start: −45d</span>
        <span style="color:var(--red);font-weight:600">▲ Deadline: −5d</span>
        <span style="color:var(--red)">Expiry</span>
        <span>${D.fmt(rMax)}</span>
      </div>
    </div>
    <div style="margin-top:12px;padding:10px 13px;background:#fff3eb;border-radius:7px;font-size:11px;color:var(--brand-deeper);border:1px solid rgba(255,107,0,.2)">
      <strong>WP Withdrawal Rule:</strong> If terminating employment, WP cancellation must be completed within <strong>15 days</strong> after the last working day.
      Exit visa valid for <strong>15 days only</strong> after WP/TRC cancellation.
    </div>
    ${dtsE<=45?`<div style="margin-top:8px;padding:10px 13px;background:var(--red-l);border-radius:7px;font-size:11px;color:var(--red-d);font-weight:500">
      🚨 TRC must also be renewed and must expire at least <strong>30 days before passport expiry</strong> (${D.fmt(e.passportExpiry)}).
    </div>`:''}
  </div>`;
}

// ── Business Trips ────────────────────────────────────
function tripsSection(e) {
  if (!e.trips.length) return '';
  return `
  <div class="sec-hdr" style="margin-top:22px">
    <div><div class="sec-title">Business Trip Visas</div><div class="sec-sub">Standalone processing timelines</div></div>
  </div>
  <div class="biz-grid" style="margin-bottom:24px">
    ${e.trips.map(t=>{
      const ready=D.add(t.appDate,t.days);
      const dLeft=D.diff(TODAY,ready);
      const prog=t.status==='completed'?100:clamp((D.diff(t.appDate,TODAY)/t.days)*100,0,100);
      const col=t.status==='completed'?'var(--green)':prog>80?'var(--warn)':'var(--brand)';
      return `
      <div class="biz-card">
        <div style="font-size:30px;margin-bottom:8px">${t.flag}</div>
        <div style="font-size:14px;font-weight:600">${t.country} Visa</div>
        <div style="font-size:11px;color:var(--txt2)">${t.type} · ${t.days}-day processing</div>
        <div style="height:1px;background:var(--border);margin:12px 0"></div>
        <div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:7px">
          <span style="color:var(--txt2)">Applied: ${D.fmt(t.appDate)}</span>
          <span style="color:var(--txt2)">Ready: ${D.fmt(ready)}</span>
        </div>
        <div class="biz-prog"><div class="biz-fill" style="width:${prog}%;background:${col}"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:10px;margin-top:5px">
          <span style="color:${col};font-weight:600">${Math.round(prog)}% complete</span>
          <span style="color:var(--txt2)">${t.status==='completed'?'✓ Ready':`~${Math.max(0,dLeft)} days left`}</span>
        </div>
      </div>`;
    }).join('')}
  </div>`;
}

// ════════════════════════════════════════════════════════
//  TOOLTIP
// ════════════════════════════════════════════════════════
function showTT(ev,name,start,end,dur,resp,notes) {
  const t=document.getElementById('tooltip');
  t.style.display='block';
  t.innerHTML=`<div class="tt-title">${name}</div>
    <div class="tt-row">Start: <span>${start}</span></div>
    <div class="tt-row">End: <span>${end}</span></div>
    <div class="tt-row">Duration: <span>${dur}</span></div>
    <div class="tt-row">Responsible: <span>${resp}</span></div>
    ${notes?`<div class="tt-row" style="margin-top:6px;color:#cbd5e1">${notes}</div>`:''}`;
  positionTT(ev);
}
function hideTT() { document.getElementById('tooltip').style.display='none'; }
function positionTT(ev) {
  const t=document.getElementById('tooltip');
  t.style.left=(ev.clientX+12)+'px'; t.style.top=(ev.clientY-10)+'px';
}
document.addEventListener('mousemove',ev=>{
  const t=document.getElementById('tooltip');
  if(t.style.display==='block') positionTT(ev);
});

// ════════════════════════════════════════════════════════
//  ADD EXPAT MODAL
// ════════════════════════════════════════════════════════
function openModal() {
  document.getElementById('f-start').value   = D.add(TODAY,30).toISOString().split('T')[0];
  document.getElementById('f-passport').value = D.add(TODAY,730).toISOString().split('T')[0];
  document.getElementById('modalOverlay').style.display='flex';
}
function closeModal() { document.getElementById('modalOverlay').style.display='none'; }
document.getElementById('modalOverlay').addEventListener('click',ev=>{
  if(ev.target===document.getElementById('modalOverlay')) closeModal();
});

function addExpat() {
  const name=document.getElementById('f-name').value.trim();
  const nat =document.getElementById('f-nat').value.trim();
  const pos =document.getElementById('f-pos').value.trim();
  const dept=document.getElementById('f-dept').value.trim();
  const sd  =new Date(document.getElementById('f-start').value);
  const pe  =new Date(document.getElementById('f-passport').value);
  if (!name||!nat||!pos||!sd) return alert('Please fill in all required fields.');
  const inits=name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase();
  const pal=['#ff6b00','#8b5cf6','#10b981','#f59e0b','#ef4444','#06b6d4','#ec4899'];
  const col=pal[EXPATS.length%pal.length];
  EXPATS.push({
    id:EXPATS.length+1,name,nat,initials:inits,color:col,
    position:pos,dept:dept||'N/A',company:'TechVN Ltd.',
    targetStart:sd,arrived:null,passportExpiry:pe,
    currentStep:1,overallStatus:'on_track',
    steps:[
      {id:1,name:"Doc. Legalization & Translation",resp:"Expat",phase:"pre",status:"in_progress",start:TODAY,end:D.add(sd,-35),notes:"In progress"},
      {id:2,name:"Demand Approval (Form 01)",resp:"Admin",phase:"pre",status:"action_required",start:D.add(sd,-30),end:D.add(sd,-15),notes:"Submit 30 days before target start"},
      {id:3,name:"Immigration Letter (Visa Approval)",resp:"Admin",phase:"pre",status:"pending",start:D.add(sd,-33),end:D.add(sd,-28),notes:""},
      {id:4,name:"WP Submission (Form 11)",resp:"Admin",phase:"pre",status:"pending",start:D.add(sd,-15),end:D.add(sd,-5),notes:""},
      {id:5,name:"Entry & Police Registration",resp:"Expat",phase:"post",status:"pending",start:sd,end:D.add(sd,3),notes:""},
      {id:6,name:"TRC Submission",resp:"Admin",phase:"post",status:"pending",start:D.add(sd,5),end:D.add(sd,15),notes:""},
      {id:7,name:"TRC Issued",resp:"Admin",phase:"post",status:"pending",start:null,end:null,notes:""}
    ],
    docs:{
      entryVisa:{lbl:"Entry Visa",          status:"pending",    issued:null,expiry:null,proc:"3–5 working days"},
      wp:       {lbl:"Work Permit",          status:"not_started",issued:null,expiry:null,proc:"5–10 working days"},
      trc:      {lbl:"Temp. Residence Card", status:"not_started",issued:null,expiry:null,proc:"7–10 working days"}
    },
    trips:[]
  });
  closeModal();
  renderSidebar();
  selectExpat(EXPATS[EXPATS.length-1].id);
}
</script>
